{
  "schemaVersion": 1,
  "rev": 1,
  "title": "Tier 2 Test 3 — list + parallel + re-gen",
  "fields": [
    {
      "id": "products",
      "type": "list",
      "label": "รายการสินค้า (กดเพิ่มแถว แล้วกรอก)",
      "item": {
        "fields": [
          { "key": "name", "label": "ชื่อสินค้า" },
          { "key": "desc", "label": "คำบรรยายภาพ (english prompt)" }
        ]
      }
    }
  ],
  "steps": [
    {
      "type": "forEach",
      "id": "prod",
      "over": "products",
      "as": "p",
      "steps": [
        {
          "type": "image",
          "id": "img",
          "model": "🍌 Nano Banana Pro",
          "aspectRatio": "9:16",
          "prompt": "clean product photo, studio lighting: {p.desc}"
        }
      ]
    }
  ],
  "policy": { "maxParallel": 2, "staggerMs": 5000 }
}
