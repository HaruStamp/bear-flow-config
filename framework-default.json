{
  "schemaVersion": 1,
  "title": "EasyBear Studio",
  "collections": {
    "shots": { "fields": ["prompt", "mood"], "slots": ["image", "video"] }
  },
  "lookups": {
    "imageModels": { "🍌 Nano Banana Pro": "🍌 Nano Banana Pro", "Imagen 4": "Imagen 4" },
    "videoModels": { "Veo 3.1 - Fast": "Veo 3.1 - Fast", "Veo 3.1 - Quality": "Veo 3.1 - Quality" },
    "moods": { "happy": "สดใส", "calm": "สงบ", "tense": "ตึงเครียด", "sad": "เศร้า" }
  },
  "values": { "style": "การ์ตูน 3D น่ารัก", "genMode": "image", "imageModel": "🍌 Nano Banana Pro", "videoModel": "Veo 3.1 - Fast", "aspect": "9:16", "review": "" },
  "seed": {
    "shots": [
      { "id": "shot_1", "fields": { "prompt": "หมีแว่นจิบกาแฟในคาเฟ่", "mood": "happy" } }
    ]
  },
  "ops": [
    { "id": "genImage", "type": "image", "over": "shots", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{values.style}, {item.prompt}, อารมณ์ {item.mood}", "out": "image" },
    { "id": "genVideo", "type": "video", "over": "shots", "model": "{values.videoModel}", "aspectRatio": "{values.aspect}", "durationSeconds": "8", "prompt": "{values.style}, {item.prompt}", "startFrame": "{item.slots.image}", "out": "video" }
  ],
  "stages": [
    { "op": "genImage" },
    { "checkpoint": "studio", "gate": { "op": "all", "from": "shots", "slot": "image" } },
    { "op": "genVideo" }
  ],
  "phases": [
    {
      "id": "studio", "title": "EasyBear Studio", "subtitle": "ตั้งค่าด้านบน · เพิ่มช็อตด้านล่าง · กดสร้าง",
      "bind": "shots",
      "form": [
        { "el": "input", "field": "style", "label": "สไตล์รวม" },
        { "el": "segmented", "field": "genMode", "label": "โหมด", "options": [ { "value": "image", "label": "ภาพ", "icon": "image" }, { "value": "video", "label": "วิดีโอ", "icon": "movie" } ] },
        { "el": "segmented", "field": "aspect", "label": "สัดส่วน", "options": [ { "value": "9:16", "label": "9:16", "icon": "crop_portrait" }, { "value": "16:9", "label": "16:9", "icon": "crop_16_9" }, { "value": "1:1", "label": "1:1", "icon": "crop_square" } ] },
        { "el": "dropdown", "field": "imageModel", "label": "โมเดลภาพ", "options": { "table": "imageModels" } },
        { "el": "dropdown", "field": "videoModel", "label": "โมเดลวิดีโอ", "when": "genMode=video", "options": { "table": "videoModels" } }
      ],
      "card": [
        { "el": "media-slot", "src": "{item.slots.video}", "when": "genMode=video" },
        { "el": "media-slot", "src": "{item.slots.image}", "when": "genMode=image" },
        { "el": "textarea", "field": "prompt", "label": "บรรยายช็อต" },
        { "el": "dropdown", "field": "mood", "label": "อารมณ์", "options": { "table": "moods" } },
        { "el": "row", "card": [
          { "el": "gen-button", "label": "เจนภาพ", "op": "genImage", "target": "{item}" },
          { "el": "gen-button", "label": "เจนวิดีโอ", "op": "genVideo", "target": "{item}", "when": "genMode=video" },
          { "el": "pick-button", "into": "{item.slots.image}" },
          { "el": "download-button", "to": "{item.slots.image}" },
          { "el": "delete-button" }
        ] }
      ]
    }
  ]
}
