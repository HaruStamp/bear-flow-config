{
  "schemaVersion": 1,
  "title": "Storyboard Slice — flim proof",
  "collections": {
    "characters": { "fields": ["name", "appearance"], "slots": ["sheet"] },
    "shots": { "fields": ["imagePrompt", "cameraAngle"], "slots": ["image"] }
  },
  "lookups": {
    "cameraAngles": { "close": "โคลสอัพ", "medium": "มุมกลาง", "wide": "มุมกว้าง" }
  },
  "seed": {
    "characters": [
      { "id": "char_1", "fields": { "name": "หมีโบ", "appearance": "หมีสีน้ำตาลใส่แว่นกันแดด สไตล์การ์ตูน 3D น่ารัก" } }
    ],
    "shots": [
      { "id": "s1", "fields": { "imagePrompt": "หมีโบนั่งจิบกาแฟในคาเฟ่อบอุ่น", "cameraAngle": "close" }, "refs": { "characters": ["char_1"] } },
      { "id": "s2", "fields": { "imagePrompt": "หมีโบเดินเล่นในสวนสาธารณะ", "cameraAngle": "wide" }, "refs": { "characters": ["char_1"] } }
    ]
  },
  "ops": [
    { "id": "genSheet", "type": "image", "over": "characters", "model": "🍌 Nano Banana Pro", "aspectRatio": "9:16",
      "prompt": "character reference sheet, {item.appearance}, full body, neutral background", "out": "sheet" },
    { "id": "genShotImage", "type": "image", "over": "shots", "model": "🍌 Nano Banana Pro", "aspectRatio": "9:16",
      "prompt": "{item.imagePrompt}, มุมกล้อง {item.cameraAngle}",
      "refs": { "op": "lookupRefs", "from": "characters", "by": "{item.refs.characters}", "slot": "sheet" }, "out": "image" }
  ],
  "stages": [
    { "op": "genSheet" },
    { "checkpoint": "studio", "gate": { "op": "all", "from": "characters", "slot": "sheet" } },
    { "op": "genShotImage" },
    { "checkpoint": "storyboard", "gate": { "op": "all", "from": "shots", "slot": "image" } }
  ],
  "phases": [
    { "id": "studio", "title": "1. ตัวละคร (Reference)", "bind": "characters", "checkpoint": true, "card": [
      { "el": "input", "field": "name" },
      { "el": "media-slot", "src": "{item.slots.sheet}", "status": "{item.status}" },
      { "el": "textarea", "field": "appearance" },
      { "el": "gen-button", "label": "เจนตัวละคร", "op": "genSheet", "target": "{item}" },
      { "el": "pick-button", "into": "{item.slots.sheet}" }
    ] },
    { "id": "storyboard", "title": "2. สตอรี่บอร์ด (ภาพช็อต)", "bind": "shots", "checkpoint": true, "card": [
      { "el": "media-slot", "src": "{item.slots.image}", "status": "{item.status}" },
      { "el": "textarea", "field": "imagePrompt" },
      { "el": "dropdown", "field": "cameraAngle", "options": { "op": "lookup", "table": "cameraAngles" } },
      { "el": "gen-button", "label": "เจนภาพ", "op": "genShotImage", "target": "{item}" },
      { "el": "pick-button", "into": "{item.slots.image}" },
      { "el": "copy-button", "value": "{item.imagePrompt}" }
    ] }
  ]
}
