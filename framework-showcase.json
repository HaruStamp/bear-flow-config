{
  "schemaVersion": 1,
  "title": "Framework Atom Showcase",
  "collections": {
    "shots": { "fields": ["prompt", "mood", "aspect"], "slots": ["image"] }
  },
  "lookups": {
    "genres": { "drama": "ดราม่า", "comedy": "ตลก", "horror": "สยอง" },
    "moods": { "happy": "สดใส", "sad": "เศร้า", "tense": "ตึงเครียด" }
  },
  "values": { "title": "โปรเจกต์ของฉัน", "genre": "drama", "style": "cartoon", "episodes": "3", "intensity": "50", "dark": "true", "brand": "#1976d2" },
  "seed": {
    "shots": [
      { "id": "s1", "fields": { "prompt": "หมีโบจิบกาแฟ", "mood": "happy", "aspect": "9:16" } },
      { "id": "s2", "fields": { "prompt": "หมีโบเดินเล่น", "mood": "sad", "aspect": "9:16" } }
    ]
  },
  "ops": [
    { "id": "genImage", "type": "image", "over": "shots", "model": "🍌 Nano Banana Pro", "aspectRatio": "{item.aspect}", "prompt": "{item.prompt}, อารมณ์ {item.mood}", "out": "image" }
  ],
  "stages": [
    { "op": "genImage" },
    { "checkpoint": "main", "gate": { "op": "all", "from": "shots", "slot": "image" } }
  ],
  "phases": [
    {
      "id": "main", "title": "Atom Showcase", "subtitle": "ฟอร์ม global ด้านบน + การ์ดต่อ item ด้านล่าง",
      "bind": "shots",
      "form": [
        { "el": "note", "value": "ทดสอบ atom ทุกชนิด — ฟอร์มนี้ผูกกับ values (global)" },
        { "el": "input", "field": "title", "label": "ชื่อโปรเจกต์" },
        { "el": "dropdown", "field": "genre", "label": "แนว", "options": { "table": "genres" } },
        { "el": "segmented", "field": "style", "label": "สไตล์", "options": [ { "value": "cartoon", "label": "การ์ตูน", "icon": "view_in_ar" }, { "value": "real", "label": "เรียลลิสติก", "icon": "photo_camera" } ] },
        { "el": "grid-select", "field": "preset", "label": "พรีเซ็ต", "cols": 3, "options": [ { "value": "ugc", "label": "UGC", "icon": "smartphone", "desc": "มือถือ" }, { "value": "ads", "label": "โฆษณา", "icon": "campaign", "desc": "ขายของ" }, { "value": "drama", "label": "ละคร", "icon": "theater_comedy", "desc": "ดราม่า" } ] },
        { "el": "row", "card": [ { "el": "stepper", "field": "episodes", "label": "ตอน" }, { "el": "number", "field": "shots", "label": "ช็อต/ตอน" } ] },
        { "el": "slider", "field": "intensity", "label": "ความเข้ม", "min": 0, "max": 100, "step": 5 },
        { "el": "switch", "field": "dark", "label": "โหมดมืด" },
        { "el": "switch", "field": "auto", "label": "โหมดอัตโนมัติ" },
        { "el": "chips", "field": "tags", "label": "แท็ก", "options": [ { "value": "drama", "label": "ดราม่า", "icon": "🎭" }, { "value": "comedy", "label": "ตลก", "icon": "😂" }, { "value": "horror", "label": "สยอง", "icon": "👻" } ] },
        { "el": "taginput", "field": "keywords", "label": "คีย์เวิร์ดอิสระ" },
        { "el": "color", "field": "brand", "label": "สีแบรนด์" },
        { "el": "divider" },
        { "el": "group", "label": "ตั้งค่าขั้นสูง", "collapsible": true, "card": [
          { "el": "switch", "field": "watermark", "label": "ลายน้ำ" },
          { "el": "number", "field": "delay", "label": "หน่วง (วิ)", "min": 0, "max": 60 }
        ] },
        { "el": "note", "when": "auto=true", "value": "✓ โหมดอัตโนมัติเปิดอยู่ (atom นี้โผล่เพราะ when=auto=true)" }
      ],
      "card": [
        { "el": "media-slot", "src": "{item.slots.image}", "status": "{item.status}" },
        { "el": "tabs", "tabs": [
          { "label": "เนื้อหา", "card": [
            { "el": "textarea", "field": "prompt", "label": "Prompt" },
            { "el": "dropdown", "field": "mood", "label": "อารมณ์", "options": { "table": "moods" } }
          ] },
          { "label": "สัดส่วน", "card": [
            { "el": "segmented", "field": "aspect", "label": "Aspect", "options": [ { "value": "9:16", "label": "9:16" }, { "value": "1:1", "label": "1:1" } ] }
          ] }
        ] },
        { "el": "row", "card": [
          { "el": "gen-button", "label": "เจน", "op": "genImage", "target": "{item}" },
          { "el": "pick-button", "into": "{item.slots.image}" },
          { "el": "download-button", "to": "{item.slots.image}" },
          { "el": "delete-button" }
        ] },
        { "el": "status-badge" }
      ]
    }
  ]
}
