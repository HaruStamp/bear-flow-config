{
  "schemaVersion": 1,
  "rev": 4,
  "title": "EasyBear Studio",
  "fields": [
    {
      "id": "prompt",
      "type": "textarea",
      "label": "อยากสร้างอะไร?",
      "default": "หมีแว่นนักสำรวจ ยืนหน้าน้ำตกกลางป่าลึก แสงทอง"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "ประเภท",
      "options": ["Image", "Video"],
      "default": "Image"
    },
    {
      "id": "imgAspect",
      "type": "select",
      "label": "สัดส่วน",
      "options": ["9:16", "16:9", "1:1", "4:3", "3:4"],
      "default": "9:16",
      "when": "mode=Image"
    },
    {
      "id": "imgModel",
      "type": "select",
      "label": "โมเดล",
      "options": ["🍌 Nano Banana Pro", "🍌 Nano Banana 2", "Imagen 4"],
      "default": "🍌 Nano Banana Pro",
      "when": "mode=Image"
    },
    {
      "id": "vidAspect",
      "type": "select",
      "label": "สัดส่วน",
      "options": ["9:16", "16:9"],
      "default": "9:16",
      "when": "mode=Video"
    },
    {
      "id": "vidModel",
      "type": "select",
      "label": "โมเดล",
      "options": ["Omni Flash", "Veo 3.1 - Fast", "Veo 3.1 - Lite", "Veo 3.1 - Quality", "Veo 3.1 - Lite [Lower Priority]"],
      "default": "Veo 3.1 - Fast",
      "when": "mode=Video"
    },
    {
      "id": "dur",
      "type": "select",
      "label": "ความยาว (วินาที) — บัญชีทั่วไป = 8",
      "options": ["8", "6", "4"],
      "default": "8",
      "when": "mode=Video"
    },
    {
      "id": "refs",
      "type": "asset-pick",
      "label": "ภาพอ้างอิง (ไม่บังคับ · แนบหลายรูปได้)",
      "multiple": true
    }
  ],
  "steps": [
    {
      "type": "image",
      "id": "image",
      "when": "mode=Image",
      "model": "{imgModel}",
      "aspectRatio": "{imgAspect}",
      "prompt": "{prompt}",
      "refs": ["refs"]
    },
    {
      "type": "video",
      "id": "video",
      "when": "mode=Video",
      "model": "{vidModel}",
      "aspectRatio": "{vidAspect}",
      "durationSeconds": "{dur}",
      "prompt": "{prompt}",
      "refs": ["refs"]
    }
  ]
}
