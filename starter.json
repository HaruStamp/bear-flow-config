{
  "schemaVersion": 1,
  "rev": 5,
  "title": "EasyBear Studio",
  "fields": [
    {
      "id": "mode",
      "type": "select",
      "label": "ประเภท",
      "widget": "toggle",
      "options": ["รูปภาพ", "วิดีโอ"],
      "default": "รูปภาพ"
    },
    {
      "id": "imgAspect",
      "type": "select",
      "label": "สัดส่วน",
      "widget": "segmented",
      "options": ["16:9", "4:3", "1:1", "3:4", "9:16"],
      "default": "9:16",
      "when": "mode=รูปภาพ"
    },
    {
      "id": "imgModel",
      "type": "select",
      "label": "โมเดล",
      "options": ["🍌 Nano Banana Pro", "🍌 Nano Banana 2", "Imagen 4"],
      "default": "🍌 Nano Banana Pro",
      "when": "mode=รูปภาพ"
    },
    {
      "id": "vidAspect",
      "type": "select",
      "label": "สัดส่วน",
      "widget": "segmented",
      "options": ["9:16", "16:9"],
      "default": "9:16",
      "when": "mode=วิดีโอ"
    },
    {
      "id": "vidModel",
      "type": "select",
      "label": "โมเดล",
      "options": ["Omni Flash", "Veo 3.1 - Fast", "Veo 3.1 - Lite", "Veo 3.1 - Quality", "Veo 3.1 - Lite [Lower Priority]"],
      "default": "Veo 3.1 - Fast",
      "when": "mode=วิดีโอ"
    },
    {
      "id": "dur",
      "type": "select",
      "label": "ความยาว (วินาที) — บัญชีทั่วไป = 8",
      "widget": "segmented",
      "options": ["4", "6", "8", "10"],
      "default": "8",
      "when": "mode=วิดีโอ"
    },
    {
      "id": "refs",
      "type": "asset-pick",
      "label": "ภาพอ้างอิง (ไม่บังคับ)",
      "multiple": true
    },
    {
      "id": "prompt",
      "type": "textarea",
      "label": "คุณต้องการสร้างอะไร?",
      "default": "หมีแว่นนักสำรวจ ยืนหน้าน้ำตกกลางป่าลึก แสงทอง"
    }
  ],
  "steps": [
    {
      "type": "image",
      "id": "image",
      "when": "mode=รูปภาพ",
      "model": "{imgModel}",
      "aspectRatio": "{imgAspect}",
      "prompt": "{prompt}",
      "refs": ["refs"]
    },
    {
      "type": "video",
      "id": "video",
      "when": "mode=วิดีโอ",
      "model": "{vidModel}",
      "aspectRatio": "{vidAspect}",
      "durationSeconds": "{dur}",
      "prompt": "{prompt}",
      "refs": ["refs"]
    }
  ]
}
